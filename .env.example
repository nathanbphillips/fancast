# FanCast environment variables
# Copy to .env.local and fill as you complete SETUP_CHECKLIST.md
# Mirror everything in the Vercel dashboard (Production + Preview).

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated Supabase user IDs with admin role (set after first signup)
ADMIN_USER_IDS=

# --- Supabase (Phase 2) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# S3-compatible storage credentials (Settings > Storage) — used by LiveKit egress (Phase 8)
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_BUCKET=recordings

# --- Ably (Phase 3) ---
ABLY_API_KEY=

# --- API-Football (Phase 2 fixtures; Phase 7 live) ---
APIFOOTBALL_KEY=
# direct API base or RapidAPI base, depending on subscription route
APIFOOTBALL_BASE=https://v3.football.api-sports.io

# --- LiveKit (Phase 5) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Stripe (Phase 9) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for monthly support tiers (create in Stripe dashboard)
STRIPE_PRICE_MONTHLY_3=
STRIPE_PRICE_MONTHLY_5=
STRIPE_PRICE_MONTHLY_10=

# --- Resend (Phase 9) ---
RESEND_API_KEY=
EMAIL_FROM="FanCast <notifications@yourdomain.com>"

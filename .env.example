# FanCast environment variables
# Copy to .env.local and fill as you complete SETUP_CHECKLIST.md
# Mirror everything in the Vercel dashboard (Production + Preview).

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated Supabase user IDs with admin role (set after first signup)
ADMIN_USER_IDS=

# --- Supabase (Phase 2) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (session pooler) — local migrations only (npm run migrate); not needed in Vercel
SUPABASE_DB_URL=
# S3-compatible storage credentials (Settings > Storage) — used by LiveKit egress (Phase 8)
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=

# --- Ably (Phase 3) ---
ABLY_API_KEY=

# --- Sportmonks football API (Phase 2 fixtures; Phase 7 live) ---
# API token from my.sportmonks.com; plan must cover the English Premier League
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE=https://api.sportmonks.com/v3/football

# --- LiveKit (Phase 5) ---
LIVEKIT_URL=
# same value, exposed to the browser for the audio client
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Stripe (Phase 9) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for monthly support tiers (create in Stripe dashboard)
STRIPE_PRICE_MONTHLY_3=
STRIPE_PRICE_MONTHLY_5=
STRIPE_PRICE_MONTHLY_10=

# --- Resend (Phase 9) ---
RESEND_API_KEY=
EMAIL_FROM="FanCast <notifications@yourdomain.com>"

# --- /dev-docs gate ---
# Password for the developer handoff page (HTTP Basic auth; any username).
# Falls back to a built-in default if unset; set this in Vercel to change it.
DEV_DOCS_PASSWORD=

# --- Web push (PRD-04 / FR-21) ---
# Generate a keypair: node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is exposed to the client; the private key is a server secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:hello@yourdomain.com"
# Absolute site URL for links in emails/push (defaults to the prod Vercel URL)
NEXT_PUBLIC_SITE_URL=
